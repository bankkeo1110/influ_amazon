# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/influ_new"

# ──────────────────────────────────────────────
# Facebook App credentials
# Create your app at https://developers.facebook.com/apps/
# Add "Facebook Login" product and enable Web OAuth Login
# Add "Pages API" product
# Required permissions: pages_manage_posts, pages_read_engagement, pages_show_list
# ──────────────────────────────────────────────
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

# OAuth redirect URI — must match exactly what you set in the Facebook App Dashboard
# e.g. http://localhost:3000/api/auth/facebook/callback
REDIRECT_URI="http://localhost:3000/api/auth/facebook/callback"

# Session encryption — must be at least 32 characters, keep secret
SESSION_SECRET="change-this-to-a-random-32-char-string-in-prod"

# Token encryption key — must be exactly 32 bytes, base64-encoded
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="base64_encoded_32_byte_key_here"
